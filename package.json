{
  "name": "god-button-action-button",
  "version": "0.1.3",
  "description": "Movable action button with RTL glass menu for mobile games.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sinzed/god-button-ui.git"
  },
  "bugs": {
    "url": "https://github.com/sinzed/god-button-ui/issues"
  },
  "homepage": "https://github.com/sinzed/god-button-ui#readme",
  "keywords": [
    "react",
    "mui",
    "rtl",
    "glass",
    "mobile",
    "draggable",
    "menu",
    "action-button"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "API.md",
    "DEVELOPMENT.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@emotion/react": ">=11",
    "@emotion/styled": ">=11",
    "@mui/material": ">=5",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
